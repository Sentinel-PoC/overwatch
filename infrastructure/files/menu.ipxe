#!ipxe

# 1. Attempt to boot from local disk first
echo Attempting to boot from local disk...
sanboot --no-describe --drive 0x80 || goto install

:install
# 2. If local boot fails, start SCOS Installer
echo Local boot failed. Starting SCOS Installer...
kernel http://10.0.0.2/scos/vmlinuz initrd=initrd.img coreos.inst.install_dev=/dev/sda coreos.inst.insecure coreos.inst.image_url=http://10.0.0.2/scos/metal.raw.gz coreos.inst.ignition_url=http://10.0.0.2/ignition/bootstrap-install.ign ip=dhcp nameserver=10.0.0.1 console=tty0 console=ttyS0,115200n8 coreos.live.rootfs_url=http://10.0.0.2/scos/rootfs.img
initrd http://10.0.0.2/scos/initrd.img
boot
