direction: right

# Physical Topology — L1
# Auto-generated by overwatch-gen. Do not edit by hand.

unifi: {
  label: "Unifi Network"
  shape: rectangle
  style.fill: "#e8f4f8"

{% for d in devices %}
  {{ d.name | replace("-", "_") | replace(".", "_") }}: {
    label: "{{ d.name }}\n{{ d.type }}\n{{ d.model }}"
    shape: rectangle
  }
{% endfor %}
}

proxmox: {
  label: "Proxmox Cluster"
  shape: rectangle
  style.fill: "#f0f8e8"

{% for node in nodes %}
  {{ node.name | replace("-", "_") }}: {
    label: "{{ node.name }}\n{{ node.maxcpu }}c / {{ (node.maxmem / 1073741824) | round(0) | int }}GB\n{{ node.status }}"
    shape: cylinder
{% set node_vms = vms | selectattr("node", "equalto", node.name) | list %}
{% if node_vms %}
{% for vm in node_vms %}
    {{ vm.name | replace("-", "_") }}: {
      label: "{{ vm.name }}\nVMID:{{ vm.vmid }}\n{{ vm.status }}"
      shape: rectangle
      style.fill: "{{ '#d4edda' if vm.status == 'running' else '#f8d7da' }}"
    }
{% endfor %}
{% endif %}
  }
{% endfor %}
}
