direction: down

# VLAN Topology — L2
# Auto-generated by overwatch-gen. Do not edit by hand.

vlans: {
  label: "VLAN Segments"
  shape: rectangle
  style.fill: "#f5f5f5"

{% for v in vlans %}
  vlan_{{ v.vlan_id }}: {
    label: "VLAN {{ v.vlan_id }}\n{{ v.name }}\n{{ v.subnet }}"
    shape: rectangle
    style.fill: "{{ '#d4edda' if v.purpose == 'corporate' else '#fff3cd' if v.purpose == 'guest' else '#f8d7da' }}"
  }
{% endfor %}
}
