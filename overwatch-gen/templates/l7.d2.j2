}
{% elif route.tls_termination == "reencrypt" %}
okd_router -> okd_workload: {
  label: "re-encrypt TLS\n({{ route.host }})"
  style.stroke: "#ff6600"
  style.stroke-dash: 3
}
{% else %}
okd_router -> okd_workload: {
  label: "edge TLS\n({{ route.host }})"
  style.stroke: "#aaaaaa"
}
{% endif %}
{% endfor %}
