direction: down

# Network Topology — L3
# Auto-generated by overwatch-gen. Do not edit by hand.

prefixes: {
  label: "IP Prefixes"
  shape: rectangle
  style.fill: "#f5f5f5"

{% for p in prefixes %}
  {{ p.prefix | replace("/", "_") | replace(".", "_") }}: {
    label: "{{ p.prefix }}\n{{ p.status }}\n{{ p.description[:40] if p.description else '' }}"
    shape: rectangle
    style.fill: "{{ '#d4edda' if p.status == 'active' else '#f8d7da' }}"
  }
{% endfor %}
}

zones: {
  label: "Firewall Zones"
  shape: rectangle
  style.fill: "#fef9e7"

{% for z in firewall_zones %}
  zone_{{ z.name | replace("-", "_") | replace(" ", "_") | lower }}: {
    label: "{{ z.name }}"
    shape: rectangle
  }
{% endfor %}
}

{% for p in firewall_policies %}
{% if p.enabled %}
# {{ p.name }}: {{ p.action }}
{% endif %}
{% endfor %}
